# ============================================
# BJJ Swarm — Environment Variables
# ============================================
# Copy to .env and fill in your API keys
# Run: cp .env.example .env

# ---- Agent Reasoning (LLM) ----
# MiniMax via LiteLLM (default for all agents)
DEFAULT_MODEL=minimax/minimax-01
MINIMAX_API_KEY=sk-your-minimax-key-here

# ---- Video Generation (OpenRouter) ----
# Default video model (swap to openai/sora-2-pro for quality)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_VIDEO_MODEL=google/veo-3.1-fast

# ---- Image Generation ----
# MiniMax image model (check platform.minimaxi.chat for model name)
MINIMAX_IMAGE_MODEL=MiniMax-Image-01

# ---- Fallback: Direct Provider Keys ----
# Only needed if NOT using OpenRouter for video, or for direct API calls
# GOOGLE_API_KEY=your-google-api-key
# OPENAI_API_KEY=your-openai-api-key
# FAL_KEY=your-fal-ai-key

# ---- Optional: Tracing ----
# OPENAI_API_KEY for agency-swarm tracing (optional)
# OPENAI_API_KEY=sk-your-openai-key-here
